{
  "protocolVersion": "0.1.0",
  "petId": "simba",
  "displayName": "辛巴",
  "description": "参考真实橘猫辛巴照片生成的毛茸茸、蓬松、慵懒风格桌面宠物，保留一只绿色眼睛和一只闭合眼睛的特征。",
  "sourceFormat": "ai-pet-protocol",
  "assets": {
