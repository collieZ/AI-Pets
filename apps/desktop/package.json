{
  "name": "@ai-pets/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "AI-Pets desktop pet app",
  "productName": "AI-Pets",
  "author": "AI-Pets",
  "type": "module",
  "main": "electron/generated/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build:electron": "node electron/build.mjs",
    "build": "pnpm build:electron && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "electron:dev": "pnpm build && electron .",
    "pack:dir": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip"
  },
  "build": {
    "appId": "cn.aipets.desktop",
    "productName": "AI-Pets",
    "icon": "assets/icon.png",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/generated/**",
      "package.json",
      "assets/**"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@ai-pets/codex-pet-adapter": "workspace:*",
    "@ai-pets/pet-protocol": "workspace:*",
    "@ai-pets/pet-renderer": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  }
}
